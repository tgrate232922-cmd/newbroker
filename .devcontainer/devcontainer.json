{
  "name": "NewBroker Laravel Dev",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "forwardPorts": [8000, 3306],
  "postCreateCommand": "chmod +x .devcontainer/setup.sh && .devcontainer/setup.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "bmewburn.vscode-intelephense-client",
        "onecentlin.laravel-blade",
        "mikestead.dotenv",
        "xdebug.php-debug"
      ]
    }
  }
}
